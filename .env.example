# Postgres warehouse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=taxi
POSTGRES_USER=taxi
POSTGRES_PASSWORD=taxi

# Airflow metadata DB (uses same Postgres in compose)
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@airflow-meta:5432/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-prod

# Pipeline settings
TAXI_DATA_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data
TAXI_DATASET=yellow_tripdata
DATA_DIR=/opt/data
LOG_LEVEL=INFO

# Anomaly detection thresholds
ROW_COUNT_DEVIATION_PCT=0.30
MIN_EXPECTED_ROWS=10000

# Alerting (leave SLACK_WEBHOOK_URL empty to log alerts only)
SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=oncall@example.com
ALERT_EMAIL_FROM=alerts@example.com
